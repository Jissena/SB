-- Heartbeat tunggal: drag + resize mainFrame + sync posisi resizeBtn
RunService.Heartbeat:Connect(function()
	if isDrag then
		local m=UIS:GetMouseLocation()
		mf.Position=UDim2.fromOffset(m.X-dOX, m.Y-dOY)
	end
	if isResizingBtn and rSM then
		local d=UIS:GetMouseLocation()-rSM
		local newW=math.clamp(rSS.X.Offset+d.X,380,800)
		local newH=math.clamp(rSS.Y.Offset+d.Y,220,600)
		mf.Size=UDim2.new(0,newW,0,newH)
		-- posisi tetap (pojok kiri atas tidak bergeser)
		mf.Position=rSP
	end
	-- Tombol pas di pojok kiri bawah GUI
	if resizeBtn.Visible then
		local ap=mf.AbsolutePosition; local as=mf.AbsoluteSize
		resizeBtn.Position=UDim2.fromOffset(ap.X+4, ap.Y+as.Y-32)
	end
end)


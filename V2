task.spawn(function()
	while true do
		task.wait(1)
		local backpack=lp:FindFirstChild("Backpack"); if not backpack then continue end
		for i,item in ipairs(infoItems) do
			local total=0
			for _,obj in pairs(backpack:GetChildren()) do
				if string.find(string.lower(obj.Name),item.key,1,true) then total+=1 end
			end
			local c2=lp.Character
			if c2 then
				for _,obj in pairs(c2:GetChildren()) do
					if obj:IsA("Tool") and string.find(string.lower(obj.Name),item.key,1,true) then total+=1 end
				end
			end
			lblRefs[i].Text=tostring(total)
		end
	end
end)

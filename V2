-- [20] LOOP AUTO SELL
-- ============================================================
local sellKeys={"large marshmallow","medium marshmallow","small marshmallow","marshmallow large","marshmallow medium","marshmallow small"}
local function equipMarsh()
	for _,k in ipairs(sellKeys) do
		for _,item in pairs(bp:GetChildren()) do
			if string.find(string.lower(item.Name),k,1,true) then item.Parent=char; return true end
		end
	end
	return false
end
local function adaMarsh()
	for _,item in pairs(bp:GetChildren()) do
		if string.find(string.lower(item.Name),"marshmallow",1,true) then return true end
	end
	return false
end
task.spawn(function()
	while true do
		task.wait(0.5)
		if isAutoSell then
			while isAutoSell and adaMarsh() do
				if equipMarsh() then task.wait(0.2);holdE(1);task.wait(0.3);unequipAll();task.wait(0.2)
				else break end
			end
		end
	end
end)


local function equipItem(nama)
	local n=string.lower(nama)
	for _,item in pairs(bp:GetChildren()) do
		if string.find(string.lower(item.Name),n,1,true) then item.Parent=char; return true end
	end
	return false
end
local function unequipAll()
	for _,tool in pairs(char:GetChildren()) do if tool:IsA("Tool") then tool.Parent=bp end end
end
local function waitEmpty()
	while char:FindFirstChildOfClass("Tool") do task.wait(0.2) end
end


-- [21] LOOP AUTO BUY
-- ============================================================
task.spawn(function()
	local SP=nil
	while true do
		task.wait(3)
		if not isAutoBuy then continue end
		if not SP then
			local ok,s=pcall(function()
				return ReplicatedStorage:WaitForChild("RemoteEvents",5):WaitForChild("StorePurchase",5)
			end)
			if ok then SP=s end
		end
		if not SP then continue end
		local jW,jS,jG=0,0,0
		for _,obj in pairs(bp:GetChildren()) do
			local n=string.lower(obj.Name)
			if string.find(n,"water",1,true)   then jW+=1 end
			if string.find(n,"sugar",1,true)   then jS+=1 end
			if string.find(n,"gelatin",1,true) then jG+=1 end
		end
		local kW=math.max(0,jumlahBeli-jW); local kS=math.max(0,jumlahBeli-jS); local kG=math.max(0,jumlahBeli-jG)
		if kW>0 or kS>0 or kG>0 then
			for _=1,kW do SP:FireServer("Water");           task.wait(0.08) end
			for _=1,kS do SP:FireServer("Sugar Block Bag"); task.wait(0.08) end
			for _=1,kG do SP:FireServer("Gelatin");         task.wait(0.08) end
		end
	end
end)


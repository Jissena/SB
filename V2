-- [8] DRAG — bisa dari mana saja di mainFrame kecuali tombol/input
local isDrag, dOX, dOY = false, 0, 0

local function isInteractive(mx, my)
	-- cek semua TextButton dan TextBox di dalam GUI
	local function checkChildren(parent)
		for _, obj in pairs(parent:GetDescendants()) do
			if (obj:IsA("TextButton") or obj:IsA("TextBox")) and obj.Visible then
				local op, os = obj.AbsolutePosition, obj.AbsoluteSize
				if mx >= op.X and mx <= op.X+os.X and my >= op.Y and my <= op.Y+os.Y then
					return true
				end
			end
		end
		return false
	end
	return checkChildren(mf)
end

UIS.InputBegan:Connect(function(i)
	if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	local mx, my = i.Position.X, i.Position.Y
	local fp, fs = mf.AbsolutePosition, mf.AbsoluteSize
	if mx < fp.X or mx > fp.X+fs.X or my < fp.Y or my > fp.Y+fs.Y then return end
	if isInteractive(mx, my) then return end
	isDrag = true; dOX = mx - fp.X; dOY = my - fp.Y
end)
UIS.InputEnded:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 then isDrag=false; isResizingBtn=false end
end)


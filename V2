local FLOOR_Y=-6; local posAsal=nil; local hbL,hbU=nil,nil

local lantai=new("Part",workspace,{
	Name="LantaiBawahTanah",Size=Vector3.new(300,1,300),
	Position=Vector3.new(0,FLOOR_Y,0),Anchored=true,CanCollide=true,
	CastShadow=false,Material=Enum.Material.SmoothPlastic,Color=Color3.fromRGB(163,162,165)
})
new("Texture",lantai,{Texture="http://www.roblox.com/asset/?id=1281477561",Face=Enum.NormalId.Top,StudsPerTileU=4,StudsPerTileV=4})

function turunKeBawahTanah()
	task.spawn(function()
		local c=lp.Character; if not c then return end
		local r=c:FindFirstChild("HumanoidRootPart"); if not r then return end
		posAsal=r.Position.Y; local tY=FLOOR_Y+3.5; local batas=posAsal-3
		lantai.Position=Vector3.new(r.Position.X,FLOOR_Y,r.Position.Z)
		task.wait(0.05); r.CFrame=CFrame.new(r.Position.X,tY,r.Position.Z)
		hbL=RunService.Heartbeat:Connect(function()
			if not isUnderground then hbL:Disconnect();hbL=nil;return end
			local c2=lp.Character;if not c2 then return end
			local r2=c2:FindFirstChild("HumanoidRootPart");if not r2 then return end
			lantai.Position=Vector3.new(r2.Position.X,FLOOR_Y,r2.Position.Z)
		end)
		hbU=RunService.Heartbeat:Connect(function()
			if not isUnderground then hbU:Disconnect();hbU=nil;return end
			local c2=lp.Character;if not c2 then return end
			local r2=c2:FindFirstChild("HumanoidRootPart");if not r2 then return end
			if r2.Position.Y>batas then r2.CFrame=CFrame.new(r2.Position.X,tY,r2.Position.Z) end
		end)
	end)
end

function naikKeAspal()
	task.spawn(function()
		if hbU then hbU:Disconnect();hbU=nil end
		if hbL then hbL:Disconnect();hbL=nil end
		local c=lp.Character;if not c then return end
		local r=c:FindFirstChild("HumanoidRootPart");if not r then return end
		r.Anchored=true
		r.CFrame=CFrame.new(r.Position.X,posAsal and posAsal+1 or 5,r.Position.Z)
		task.wait(0.2);r.Anchored=false;posAsal=nil
	end)
end

